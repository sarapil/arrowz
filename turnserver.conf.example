# Coturn TURN Server Configuration for FreePBX/Asterisk WebRTC
# File: /etc/turnserver.conf (inside container)
# Or: ./fpbx_data/etc/turnserver.conf (on host)

# =============================================================================
# NETWORK SETTINGS
# =============================================================================

# TURN listener port (default: 3478)
listening-port=3478

# TLS/DTLS listener port (default: 5349)
tls-listening-port=5349

# Listen on all interfaces
listening-ip=0.0.0.0

# Alternative listening port (some firewalls block 3478)
alt-listening-port=3479
alt-tls-listening-port=5350

# =============================================================================
# EXTERNAL IP (CRITICAL for NAT/Docker)
# =============================================================================

# Public IP of your server - CHANGE THIS!
external-ip=157.173.125.136

# If server has multiple IPs, specify both:
# external-ip=PUBLIC_IP/PRIVATE_IP
# external-ip=157.173.125.136/172.23.0.2

# =============================================================================
# REALM & SERVER NAME
# =============================================================================

realm=pbx.tavira-group.com
server-name=pbx.tavira-group.com

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Use long-term credential mechanism
lt-cred-mech

# Static user credentials (username:password)
user=webrtc:Arrowz2024!

# Additional users (add as needed)
# user=user2:password2

# =============================================================================
# RELAY SETTINGS
# =============================================================================

# Relay IP (usually same as external-ip)
relay-ip=0.0.0.0

# Min/Max ports for relay (match Asterisk RTP range)
min-port=10500
max-port=10700

# =============================================================================
# SECURITY
# =============================================================================

# Enable fingerprinting (required for WebRTC)
fingerprint

# No CLI (security)
no-cli

# No multicast peers
no-multicast-peers

# Disable UDP self-reflection (security)
no-loopback-peers

# Stale nonce lifetime
stale-nonce=600

# =============================================================================
# ALLOWED PEERS (Asterisk container network)
# =============================================================================

# Allow relay to these networks
allowed-peer-ip=172.23.0.0-172.23.255.255
allowed-peer-ip=10.0.0.0-10.255.255.255
allowed-peer-ip=192.168.0.0-192.168.255.255
allowed-peer-ip=0.0.0.0-255.255.255.255

# =============================================================================
# PERFORMANCE
# =============================================================================

# Total allocation quota
total-quota=100

# Max bandwidth per session (0 = unlimited)
bps-capacity=0

# =============================================================================
# LOGGING
# =============================================================================

# Log file
log-file=/var/log/turnserver.log

# Verbose logging (enable for debugging, disable in production)
verbose

# No stdout logging (use file only)
no-stdout-log

# =============================================================================
# TLS/DTLS (Optional - for secure TURN)
# =============================================================================

# If you have SSL certificates, uncomment these:
# cert=/etc/ssl/certs/your-cert.pem
# pkey=/etc/ssl/private/your-key.pem

# =============================================================================
# ADDITIONAL OPTIONS
# =============================================================================

# Enable TURN REST API for time-limited credentials
# use-auth-secret
# static-auth-secret=YOUR_SECRET_HERE

# Keep alive interval (for NAT)
# channel-lifetime=600

# Allocation lifetime
# max-allocate-lifetime=3600
