# ================== Security ====================

# Never commit these
*.p12
*.pfx
*.jks
.htpasswd
.htaccess

# AWS credentials
.aws/
aws_credentials

# Google Cloud
*.json.enc
service-account*.json

# API keys file
api_keys.txt
api_keys.json

# ================== Production ====================

# Production config (use environment variables instead)
production.json
prod_config.json

# Supervisor config with passwords
supervisord.conf

# Nginx config with SSL paths
nginx.conf

# ================== Exceptions ====================

# Keep these files even if they match patterns above
!.gitkeep
!.env.example
!docker-compose.example.yml
!example_*.json
!test_fixtures/

# AI Tools
.aider*
.copilot/
.cursor/
